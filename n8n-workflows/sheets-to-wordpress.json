{
  "name": "Sheets to WordPress bitebimuv.org",
  "meta": { "instanceId": "dernek-system" },
  "nodes": [
    {
      "id": "1", "name": "Saatlik Tetikleyici",
      "type": "n8n-nodes-base.scheduleTrigger",
      "parameters": { "rule": { "interval": [{ "field": "hours", "hoursInterval": 1 }] } },
      "position": [250, 300]
    },
    {
      "id": "2", "name": "Sheets Oku",
      "type": "n8n-nodes-base.googleSheets",
      "parameters": {
        "operation": "read",
        "documentId": { "mode": "id", "value": "1tDehgecGUQEQZ1H5n6F2XxfXZw30sRhYfWe1grQjc9Y" },
        "sheetName": "Projeler",
        "dataLocationOnSheet": { "values": { "rangeDefinition": "specifyRange", "range": "A2:L200" } }
      },
      "position": [450, 300]
    },
    {
      "id": "3", "name": "Yayina Hazir Filtre",
      "type": "n8n-nodes-base.filter",
      "parameters": {
        "conditions": {
          "conditions": [{ "id": "1", "leftValue": "={{ $json['Asama'] }}", "rightValue": "Yayina Hazir", "operator": { "type": "string", "operation": "equals" } }]
        }
      },
      "position": [650, 300]
    },
    {
      "id": "4", "name": "WP Post Olustur",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "url": "https://bitebimuv.org/wp-json/royal-mcp/v1/mcp",
        "method": "POST",
        "sendHeaders": true,
        "headerParameters": { "parameters": [
          { "name": "X-Royal-MCP-API-Key", "value": "{{ $env.ROYAL_MCP_API_KEY }}" },
          { "name": "Content-Type", "value": "application/json" }
        ]},
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"tools/call\",\n  \"params\": {\n    \"name\": \"wp_create_post\",\n    \"arguments\": {\n      \"title\": \"{{ $json['Proje Adi'] }}\",\n      \"content\": \"Arac: {{ $json['Birincil Arac'] }}\\nToken: {{ $json['Toplam Token'] }}\\nMaliyet: {{ $json['Toplam Maliyet USD'] }} USD\",\n      \"status\": \"draft\",\n      \"type\": \"post\"\n    }\n  },\n  \"id\": 1\n}"
      },
      "position": [850, 300]
    }
  ],
  "connections": {
    "Saatlik Tetikleyici": { "main": [[{ "node": "Sheets Oku" }]] },
    "Sheets Oku": { "main": [[{ "node": "Yayina Hazir Filtre" }]] },
    "Yayina Hazir Filtre": { "main": [[{ "node": "WP Post Olustur" }]] }
  }
}
